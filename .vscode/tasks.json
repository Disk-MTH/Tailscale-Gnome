{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Install",
            "detail": "Build schemas and copy the extension to ~/.local/share/gnome-shell/extensions",
            "type": "shell",
            "command": "make",
            "args": ["install"],
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "silent", "clear": true, "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Pack release",
            "detail": "Produce tailscale-gnome@diskmth.fr.shell-extension.zip for extensions.gnome.org",
            "type": "shell",
            "command": "make",
            "args": ["pack"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Open preferences",
            "detail": "Spawn the Adwaita prefs dialog (re-reads prefs.js every time)",
            "type": "shell",
            "command": "gnome-extensions",
            "args": ["prefs", "tailscale-gnome@diskmth.fr"],
            "presentation": { "reveal": "silent", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Tail extension logs",
            "detail": "journalctl --user -f filtered for tailscale + extension. Run in a dedicated terminal.",
            "type": "shell",
            "command": "journalctl --user -f /usr/bin/gnome-shell | grep --line-buffered -iE 'tailscale|extension'",
            "isBackground": true,
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
            "problemMatcher": []
        },
        {
            "label": "Launch nested GNOME Shell",
            "detail": "Open a fresh Wayland window running a child gnome-shell — fastest way to iterate without re-login",
            "type": "shell",
            "command": "dbus-run-session -- gnome-shell --nested --wayland",
            "isBackground": true,
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
            "problemMatcher": []
        },
        {
            "label": "Validate syntax",
            "detail": "node --check on every JS file",
            "type": "shell",
            "command": "for f in extension.js prefs.js lib/*.js; do printf '%-25s ' \"$f\"; node --check \"$f\" && echo OK; done",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": []
        }
    ]
}
